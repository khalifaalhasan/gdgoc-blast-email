FROM node:20-alpine AS builder

WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY . .

# Build args
ARG VITE_API_URL
ARG VITE_EMAIL_ASSET_BASE_URL
ARG VITE_LINK_INSTAGRAM
ARG VITE_LINK_LINKEDIN
ARG VITE_LINK_GITHUB
ARG VITE_LINK_WEBSITE

ENV VITE_API_URL=$VITE_API_URL
ENV VITE_EMAIL_ASSET_BASE_URL=$VITE_EMAIL_ASSET_BASE_URL
ENV VITE_LINK_INSTAGRAM=$VITE_LINK_INSTAGRAM
ENV VITE_LINK_LINKEDIN=$VITE_LINK_LINKEDIN
ENV VITE_LINK_GITHUB=$VITE_LINK_GITHUB
ENV VITE_LINK_WEBSITE=$VITE_LINK_WEBSITE

RUN npm run build

FROM nginx:alpine
COPY --from=builder /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
