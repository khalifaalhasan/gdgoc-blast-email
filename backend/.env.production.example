# --- GOOGLE API ---
# Di environment production, token.json dan credentials.json harus diletakkan 
# secara aman di root direktori backend atau mount sebagai volume jika menggunakan Docker.

# --- SYSTEM SETTINGS ---
# Gunakan nama service redis jika menjalankan redis via docker-compose (contoh: redis)
REDIS_URL=redis://redis:6379/0
# Ganti dengan domain production frontend Anda untuk keperluan CORS
FRONTEND_URL=https://blast.gdgunsri.com

# --- EMAIL CONFIGURATION ---
SENDER_NAME="GDG on Campus UNSRI"
